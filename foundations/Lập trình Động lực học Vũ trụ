```cpp
// NKTg 即時控制器 --- ESP32 + 真實感測器
// 生產版本: MPU6050 + 編碼器 + 負載感測器
// 透過 USB 將 "x,v,m,dm_dt" 數據發送到 NKTg_System.html
#include <Wire.h>
#include <MPU6050.h>
#include <HX711.h>
// --- 硬體宣告 ---
MPU6050 imu;
HX711 loadcell;
// 編碼器引腳
#define ENC_L_A 34
#define ENC_L_B 35
#define ENC_R_A 36
#define ENC_R_B 39
// 馬達驅動器 BTS7960
#define MOTOR_RPWM 25
#define MOTOR_LPWM 26
#define MOTOR_EN 27
// 負載感測器引腳
#define HX711_DT 4
#define HX711_SCK 5
// --- 全域變數 ---
volatile long encoderCount = 0;
float x = 0;          // 位置 (m)
float v = 0;          // 速度 (m/s)
float m_prev = 0;     // 上一次質量 (kg)
float m_curr = 0;     // 當前質量 (kg)
float dm_dt = 0;      // 質量變化率 (kg/s)
const float WHEEL_CIRCUMFERENCE = 0.2;   // 車輪周長 (m)
const int PPR = 600;                      // 編碼器每轉脈衝數
const float LOADCELL_SCALE = 2280.0;      // 負載感測器校正係數
unsigned long lastTime = 0;
unsigned long lastSend = 0;
const unsigned long DT = 10;              // 10ms = 100Hz 內部計算
const unsigned long SEND_INTERVAL = 50;   // 50ms = 20Hz 發送到網頁
// --- 編碼器中斷 ---
void IRAM_ATTR encoderISR() {
    if (digitalRead(ENC_L_B) > 0) encoderCount++;
    else encoderCount--;
}
// --- 設定 ---
void setup() {
    Serial.begin(115200);
    while (!Serial) delay(10);
    Wire.begin();
    // 初始化 IMU
    imu.initialize();
    if (!imu.testConnection()) {
        Serial.println("MPU6050 失敗");
        while(1);
    }
    // 初始化負載感測器
    loadcell.begin(HX711_DT, HX711_SCK);
    loadcell.set_scale(LOADCELL_SCALE);
    loadcell.tare();  // 歸零
    // 編碼器
    pinMode(ENC_L_A, INPUT_PULLUP);
    pinMode(ENC_L_B, INPUT_PULLUP);
    attachInterrupt(digitalPinToInterrupt(ENC_L_A), encoderISR, RISING);
    // 馬達驅動器
    ledcSetup(0, 5000, 8);
    ledcSetup(1, 5000, 8);
    ledcAttachPin(MOTOR_RPWM, 0);
    ledcAttachPin(MOTOR_LPWM, 1);
    pinMode(MOTOR_EN, OUTPUT);
    digitalWrite(MOTOR_EN, HIGH);
    m_curr = loadcell.get_units(5);  // 讀取初始質量
    m_prev = m_curr;
    lastTime = millis();
    Serial.println("READY");  // 與網頁握手
}
// --- 計算 NKTg ---
float nktg1(float x, float v, float m) {
    return x * (m * v);
}
float nktg2(float dm_dt, float v, float m) {
    return dm_dt * (m * v);
}
// --- 基於 NKTg 的馬達控制 ---
void driveMotor(float n1, float n2) {
    const float DANGER_N1 = 500.0;
    const float DANGER_N2 = -50.0;
    const int NORMAL_SPEED = 180;  // 0--255 PWM
    if (n1 > DANGER_N1) {
        // NKTg_1 正且大 = 不穩定 → 緊急煞車
        ledcWrite(0, 0);
        ledcWrite(1, 0);
    } else if (n2 < DANGER_N2) {
        // NKTg_2 負且大 = 質量突然損失 → 減速
        ledcWrite(0, NORMAL_SPEED * 0.5);
        ledcWrite(1, 0);
    } else {
        // 穩定 → 正常行駛
        ledcWrite(0, NORMAL_SPEED);
        ledcWrite(1, 0);
    }
}
// --- 主迴圈 ---
void loop() {
    unsigned long now = millis();
    // --- 100Hz: 物理計算 ---
    if (now - lastTime >= DT) {
        float dt_sec = (now - lastTime) / 1000.0;
        lastTime = now;
        // 從編碼器計算速度
        long count = encoderCount;
        encoderCount = 0;
        float distance = (float)count / PPR * WHEEL_CIRCUMFERENCE;
        v = distance / dt_sec;   // m/s
        x += distance;            // 累積位置
        // 從負載感測器讀取質量
        if (loadcell.is_ready()) {
            m_prev = m_curr;
            m_curr = max(0.1f, loadcell.get_units());
            dm_dt = (m_curr - m_prev) / dt_sec;  // kg/s
        }
        // 計算 NKTg 並控制馬達
        float n1 = nktg1(x, v, m_curr);
        float n2 = nktg2(dm_dt, v, m_curr);
        driveMotor(n1, n2);
    }
    // --- 20Hz: 發送數據到網頁 ---
    if (now - lastSend >= SEND_INTERVAL) {
        lastSend = now;
        // 格式: "x,v,m,dm_dt\n"
        Serial.print(x, 3); Serial.print(",");
        Serial.print(v, 3); Serial.print(",");
        Serial.print(m_curr, 3); Serial.print(",");
        Serial.println(dm_dt, 4);
    }
}
```
