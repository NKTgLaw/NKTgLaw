namespace NKTgQuantum {
    open Microsoft.Quantum.Intrinsic;
    open Microsoft.Quantum.Math;
    function Tendency1(n : Double) : String {
        if (n > 0.0) { return "Moving away from stable state"; }
        elif (n < 0.0) { return "Moving toward stable state"; }
        else { return "Stable equilibrium"; }
    }
    function Tendency2(n : Double) : String {
        if (n > 0.0) { return "Mass variation supports movement"; }
        elif (n < 0.0) { return "Mass variation resists movement"; }
        else { return "No mass variation effect"; }
    }
    operation RunNKTg() : Unit {
        let x = 2.0;
        let v = 3.0;
        let m = 5.0;
        let dm_dt = -0.5;
        let p = m * v; // p = m × v
        let nktg1 = x * p; // NKTg₁ = x × p
        let nktg2 = dm_dt * p; // NKTg₂ = (dm/dt) × p
        Message($"p={p}");
        Message($"NKTg1={nktg1}");
        Message($"NKTg2={nktg2}");
        Message($"tendency1={Tendency1(nktg1)}");
        Message($"tendency2={Tendency2(nktg2)}");
    }
}
