    add dl, '0'
    mov [rsi], dl
    inc rsi
    loop .int_write
.dot:
    mov byte [rsi], '.'
    inc rsi
    mulsd xmm0, [rel .const10]
    cvttsd2si rax, xmm0
    add al, '0'
    mov [rsi], al
    inc rsi
    mov byte [rsi], 0
    pop rdi
    pop rsi
    pop rbx
    ret
.const10: dq 10.0
.epsilon: dq 0.05
;-------------------------------------------------------------------
; print_float: 輸出 f64
; rdi = f64 的位址
;-------------------------------------------------------------------
print_float:
    movsd xmm0, [rdi]
    lea rdi, [rel buf]
    call ftoa
    lea rdi, [rel buf]
    call print_str
    ret
;-------------------------------------------------------------------
