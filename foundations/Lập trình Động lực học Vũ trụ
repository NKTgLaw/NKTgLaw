    def __init__(self, m0=5.0, dm_dt=-0.01):
        self.x, self.v, self.m = 0.0, 0.0, m0
        self.dm_dt = dm_dt
    def nktg_engine(self):
        p = self.m * self.v
        nktg1 = self.x * p
        nktg2 = self.dm_dt * p
        return nktg1, nktg2
    def step(self, action, dt=0.001):
        self.m = max(0.1, self.m + self.dm_dt * dt)
